digraph G {
graph [rankdir=LR bgcolor="white" margin=0.18 pad=0.24 nodesep=0.55 ranksep=0.6 labelloc="t" label="42: finalize the side with the smaller max" fontsize=18 fontname="Helvetica-Bold"]
node [fontname="Helvetica" fontsize=12 color="#94A3B8"]
edge [fontname="Helvetica" fontsize=11 color="#64748B" arrowsize=0.7]
window [shape=plain label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" COLSPAN="9" CELLPADDING="10"><B><FONT POINT-SIZE="13">Current window</FONT></B></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">i</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">0</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">1</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">2</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">3</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">4</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">5</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">6</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">7</FONT></B></TD></TR><TR><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">height</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">0</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">0</FONT></TD><TD BGCOLOR="#FDE68A" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">2</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">0</FONT></TD><TD BGCOLOR="#DCFCE7" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">3</FONT></TD></TR><TR><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">role</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11"> </FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11"> </FONT></TD><TD BGCOLOR="#DBEAFE" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11"> </FONT></TD><TD BGCOLOR="#FDE68A" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">left_max=2</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">l</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11"> </FONT></TD><TD BGCOLOR="#DCFCE7" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11"> </FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">right_max=3</FONT></TD></TR></TABLE>>];
fact [shape=box style="rounded,filled" fillcolor="#DCFCE7" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Finalization step
left_max = 2 <= right_max = 3
water(4) = 2 - 1 = 1
index 4 can be finalized now"];
move [shape=box style="rounded,filled" fillcolor="#FDE68A" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Pointer consequence
add 1 to the answer
increment l
future right choices cannot reduce the bound"];
window -> fact [label="read state"];
fact -> move [label="justifies move"];
}
