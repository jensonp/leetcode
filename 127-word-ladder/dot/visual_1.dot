digraph G {
graph [rankdir=LR bgcolor="white" margin=0.18 pad=0.24 nodesep=0.55 ranksep=0.6 labelloc="t" label="127: Word Ladder: core proof map" fontsize=18 fontname="Helvetica-Bold"]
node [fontname="Helvetica" fontsize=12 color="#94A3B8"]
edge [fontname="Helvetica" fontsize=11 color="#64748B" arrowsize=0.7]
top [shape=plaintext fontname="Helvetica-Bold" fontsize=15 label="127: Word Ladder"];
state [shape=box style="rounded,filled" fillcolor="#DBEAFE" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="State Model
Vertices are the words in
`wordList` together with
`beginWord`. Two words are
adjacent if they differ in
exactly one position."];
claim [shape=box style="rounded,filled" fillcolor="#DCFCE7" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="BFS Layer Lemma
In an unweighted graph, BFS
visits vertices in
nondecreasing shortest-path
distance from the source.
..."];
action [shape=box style="rounded,filled" fillcolor="#FDE68A" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Algorithm Consequence
Insert the dictionary into a
hash set. 2. If `endWord` is
absent, return `0`. 3. Run BFS
from `beginWord`."];
proof [shape=box style="rounded,filled" fillcolor="#FCE7F3" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Why It Works
The BFS layer lemma guarantees
that vertices are dequeued in
shortest-path order."];
top -> state [style=invis];
state -> claim [label="sets up"];
claim -> action [label="justifies"];
action -> proof [label="preserves"];
{ rank=same; state; claim; action; proof }
}
