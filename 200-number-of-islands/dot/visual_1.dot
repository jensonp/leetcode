digraph G {
graph [rankdir=LR bgcolor="white" margin=0.18 pad=0.24 nodesep=0.55 ranksep=0.6 labelloc="t" label="200: Number of Islands: core proof map" fontsize=18 fontname="Helvetica-Bold"]
node [fontname="Helvetica" fontsize=12 color="#94A3B8"]
edge [fontname="Helvetica" fontsize=11 color="#64748B" arrowsize=0.7]
top [shape=plaintext fontname="Helvetica-Bold" fontsize=15 label="200: Number of Islands"];
state [shape=box style="rounded,filled" fillcolor="#DBEAFE" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="State Model
A land cell belongs to exactly
one island, namely its maximal
4-connected component."];
claim [shape=box style="rounded,filled" fillcolor="#DCFCE7" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Component-Coverage Lemma
A DFS or BFS started from an
unvisited land cell visits
exactly the cells in its
4-connected component and no
..."];
action [shape=box style="rounded,filled" fillcolor="#FDE68A" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Algorithm Consequence
Scan every grid cell. Whenever
an unvisited land cell is
found, increment the island
count and flood-fill its
component."];
proof [shape=box style="rounded,filled" fillcolor="#FCE7F3" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Why It Works
If the scan sees water or an
already visited cell, it does
nothing, which is correct
because that cell cannot begin
a new island."];
top -> state [style=invis];
state -> claim [label="sets up"];
claim -> action [label="justifies"];
action -> proof [label="preserves"];
{ rank=same; state; claim; action; proof }
}
