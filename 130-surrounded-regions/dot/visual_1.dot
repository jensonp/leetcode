digraph G {
graph [rankdir=LR bgcolor="white" margin=0.18 pad=0.24 nodesep=0.55 ranksep=0.6 labelloc="t" label="130: Surrounded Regions: core proof map" fontsize=18 fontname="Helvetica-Bold"]
node [fontname="Helvetica" fontsize=12 color="#94A3B8"]
edge [fontname="Helvetica" fontsize=11 color="#64748B" arrowsize=0.7]
top [shape=plaintext fontname="Helvetica-Bold" fontsize=15 label="130: Surrounded Regions"];
state [shape=box style="rounded,filled" fillcolor="#DBEAFE" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="State Model
A cell is safe if it is an
`'O'` connected to at least
one boundary `'O'` by a
4-directional path of `'O'`
cells."];
claim [shape=box style="rounded,filled" fillcolor="#DCFCE7" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Boundary-Reachability Lemma
An `'O'` cell survives exactly
when it is boundary-reachable.
Any region not touching the
boundary is surrounded and
must be flipped."];
action [shape=box style="rounded,filled" fillcolor="#FDE68A" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Algorithm Consequence
Start DFS or BFS from every
boundary `'O'` and mark every
reached `'O'` as safe, for
example with a temporary
..."];
proof [shape=box style="rounded,filled" fillcolor="#FCE7F3" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Why It Works
By the boundary-reachability
lemma, every cell reached from
a boundary `'O'` must survive."];
top -> state [style=invis];
state -> claim [label="sets up"];
claim -> action [label="justifies"];
action -> proof [label="preserves"];
{ rank=same; state; claim; action; proof }
}
