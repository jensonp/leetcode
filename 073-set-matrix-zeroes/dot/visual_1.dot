digraph G {
graph [rankdir=LR bgcolor="white" margin=0.18 pad=0.24 nodesep=0.55 ranksep=0.6 labelloc="t" label="73: reuse the matrix itself as marker storage" fontsize=18 fontname="Helvetica-Bold"]
node [fontname="Helvetica" fontsize=12 color="#94A3B8"]
edge [fontname="Helvetica" fontsize=11 color="#64748B" arrowsize=0.7]
matrix [shape=plain label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" COLSPAN="5" CELLPADDING="10"><B><FONT POINT-SIZE="13">Interior zeros write row / column markers</FONT></B></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11"> </FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">0</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">1</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">2</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">3</FONT></B></TD></TR><TR><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">0</FONT></TD><TD BGCOLOR="#DCFCE7" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD><TD BGCOLOR="#FDE68A" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">0</FONT></TD><TD BGCOLOR="#DCFCE7" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD></TR><TR><TD BGCOLOR="#DCFCE7" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">0</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD></TR><TR><TD BGCOLOR="#DCFCE7" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">2</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD><TD BGCOLOR="#FDE68A" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">0</FONT></TD></TR><TR><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">3</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD></TR></TABLE>>];
corner [shape=box style="rounded,filled" fillcolor="#FCE7F3" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Special case
matrix[0][0] cannot encode
both the first row and
the first column alone"];
flags [shape=box style="rounded,filled" fillcolor="#DBEAFE" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Saved separately
first_row_zero
first_col_zero"];
matrix -> corner [label="why booleans exist"];
corner -> flags [label="store border metadata"];
}
