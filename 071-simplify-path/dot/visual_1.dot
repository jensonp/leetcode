digraph G {
graph [rankdir=LR bgcolor="white" margin=0.18 pad=0.24 nodesep=0.55 ranksep=0.6 labelloc="t" label="71: Simplify Path: core proof map" fontsize=18 fontname="Helvetica-Bold"]
node [fontname="Helvetica" fontsize=12 color="#94A3B8"]
edge [fontname="Helvetica" fontsize=11 color="#64748B" arrowsize=0.7]
top [shape=plaintext fontname="Helvetica-Bold" fontsize=15 label="71: Simplify Path"];
state [shape=box style="rounded,filled" fillcolor="#DBEAFE" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="State Model
Split the path on `'/'` and
process each token with a
stack of canonical directory
names."];
claim [shape=box style="rounded,filled" fillcolor="#DCFCE7" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Canonical-Prefix Invariant
After processing any prefix of
the tokens, the stack equals
the canonical directory
sequence for that prefix.
..."];
action [shape=box style="rounded,filled" fillcolor="#FDE68A" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Algorithm Consequence
Scan the tokens and update the
stack by the rules above."];
proof [shape=box style="rounded,filled" fillcolor="#FCE7F3" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Why It Works
The canonical-prefix invariant
holds initially for the empty
token prefix, whose canonical
directory list is empty."];
top -> state [style=invis];
state -> claim [label="sets up"];
claim -> action [label="justifies"];
action -> proof [label="preserves"];
{ rank=same; state; claim; action; proof }
}
