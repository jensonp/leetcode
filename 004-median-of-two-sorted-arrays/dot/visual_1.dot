digraph G {
graph [rankdir=TB bgcolor="white" margin=0.18 pad=0.24 nodesep=0.55 ranksep=0.6 labelloc="t" label="4: search for the unique feasible partition" fontsize=18 fontname="Helvetica-Bold"]
node [fontname="Helvetica" fontsize=12 color="#94A3B8"]
edge [fontname="Helvetica" fontsize=11 color="#64748B" arrowsize=0.7]
a [shape=plain label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" COLSPAN="6" CELLPADDING="10"><B><FONT POINT-SIZE="13">Partition in A</FONT></B></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">A</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">0</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">1</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">2</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">3</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">4</FONT></B></TD></TR><TR><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">value</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">3</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">8</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">9</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">15</FONT></TD></TR><TR><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">cut</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">L</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">L</FONT></TD><TD BGCOLOR="#FDE68A" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">|</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">R</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">R</FONT></TD></TR></TABLE>>];
b [shape=plain label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" COLSPAN="7" CELLPADDING="10"><B><FONT POINT-SIZE="13">Partition in B</FONT></B></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">B</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">0</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">1</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">2</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">3</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">4</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">5</FONT></B></TD></TR><TR><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">value</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">7</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">11</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">18</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">19</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">21</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">25</FONT></TD></TR><TR><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">cut</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">L</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">L</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">L</FONT></TD><TD BGCOLOR="#FDE68A" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">|</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">R</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">R</FONT></TD></TR></TABLE>>];
bounds [shape=box style="rounded,filled" fillcolor="#DCFCE7" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Boundary values
Aleft = 8, Aright = 9
Bleft = 19, Bright = 21
check Aleft <= Bright and Bleft <= Aright"];
direction [shape=box style="rounded,filled" fillcolor="#FDE68A" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Binary-search direction
if Aleft > Bright: move i left
if Bleft > Aright: move i right"];
a -> bounds [style=invis];
b -> bounds [style=invis];
bounds -> direction [label="decides move"];
}
