NT POINT-SIZE="10" COLOR="#0F172A">(3,4)<BR/>A=2</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#0F172A">(3,5)<BR/>A=4</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#0F172A">(3,6)<BR/>A=6</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#0F172A">(3,7)<BR/>A=8</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#0F172A">(3,8)<BR/>A=10</FONT></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>4</B></FONT></TD><TD BGCOLOR="#F8FAFC" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"> </FONT></TD><TD BGCOLOR="#F8FAFC" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"> </FONT></TD><TD BGCOLOR="#F8FAFC" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"> </FONT></TD><TD BGCOLOR="#F8FAFC" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"> </FONT></TD><TD BGCOLOR="#F8FAFC" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"> </FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#0F172A">(4,5)<BR/>A=4</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#0F172A">(4,6)<BR/>A=10</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#0F172A">(4,7)<BR/>A=9</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#0F172A">(4,8)<BR/>A=20</FONT></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>5</B></FONT></TD><TD BGCOLOR="#F8FAFC" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FON