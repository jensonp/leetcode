proof [shape=box style="rounded,filled" fillcolor="#FEE2E2" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" label="Why row 0 is safe to prune\\nEvery (0, k) is narrower than (0, 8).\\nIts water level is still capped at 1."];
prune -> proof [style=dashed];
}
