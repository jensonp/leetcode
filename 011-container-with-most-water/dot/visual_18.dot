digraph G {
graph [rankdir=LR bgcolor="white" margin=0.18 pad=0.2 nodesep=0.45 ranksep=0.5 splines=line]
node [fontname="Helvetica" fontsize=12 color="#94A3B8"]
edge [fontname="Helvetica" fontsize=11 color="#64748B" arrowsize=0.7]
s1 [shape=box style="rounded,filled" fillcolor="#DBEAFE" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" label="(0, 8)\\nwidth = 8"];
s2 [shape=box style="rounded,filled" fillcolor="#ECFCCB" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" label="(1, 8)\\nwidth = 7"];
s3 [shape=box style="rounded,filled" fillcolor="#DBEAFE" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" label="(1, 7)\\nwidth = 6"];
s4 [shape=box style="rounded,filled" fillcolor="#DBEAFE" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" label="(1, 6)\\nwidth = 5"];
s5 [shape=box style="rounded,filled" fillcolor="#DBEAFE" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" label="(1, 5)\\nwidth = 4"];
s6 [shape=box style="rounded,filled" fillcolor="#DBEAFE" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" label="(1, 4)\\nwidth = 3"];
s7 [shape=box style="rounded,filled" fillcolor="#DBEAFE" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" label="(1, 3)\\nwidth = 2"];
s8 [shape=box style="rounded,filled" fillcolor="#DBEAFE" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" label="(1, 2)\\nwidth = 1"];
done [shape=box style="rounded,filled" fillcolor="#FEE2E2" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" label="Stop\\nPointers meet at (1, 1)\\nNo width remains."];
s1 -> s2 [label="move left"];
s2 -> s3 [label="move right"];
s3 -> s4 [label="move right"];
s4 -> s5 [label="move either"];
s5 -> s6 [label="move right"];
s6 -> s7 [label="move right"];
s7 -> s8 [label="move right"];
s8 -> done [label="move right"];
}
