digraph G {
graph [rankdir=TB bgcolor="white" margin=0.18 pad=0.2 nodesep=0.45 ranksep=0.5 splines=line]
node [fontname="Helvetica" fontsize=12 color="#94A3B8"]
edge [fontname="Helvetica" fontsize=11 color="#64748B" arrowsize=0.7]
start [shape=plain label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8" COLSPAN="10"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>Current pair</B></FONT></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>index</B></FONT></TD><TD BGCOLOR="#BFDBFE" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>0</B></FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">1</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">2</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">3</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">4</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">5</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">6</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">7</FONT></TD><TD BGCOLOR="#FCD34D" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>8</B></FONT></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>height</B></FONT></TD><TD BGCOLOR="#BFDBFE" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>1</B></FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">8</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">6</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">2</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">5</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">4</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">8</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">3</FONT></TD><TD BGCOLOR="#FCD34D" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>7</B></FONT></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>role</B></FONT></TD><TD BGCOLOR="#BFDBFE" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#0F172A">shorter</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FCD34D" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#0F172A">taller</FONT></TD></TR></TABLE>>];
start_note [shape=box style="rounded,filled" fillcolor="#F8FAFC" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" label="Area now\\n(8 - 0) * min(1, 7) = 8"];
wrong [shape=plain label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8" COLSPAN="10"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>Wrong move: keep the short wall, move the taller wall</B></FONT></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>index</B></FONT></TD><TD BGCOLOR="#BFDBFE" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>0</B></FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">1</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">2</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">3</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">4</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">5</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">6</FONT></TD><TD BGCOLOR="#FCD34D" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>7</B></FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">8</FONT></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>height</B></FONT></TD><TD BGCOLOR="#BFDBFE" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>1</B></FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">8</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">6</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">2</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">5</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">4</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">8</FONT></TD><TD BGCOLOR="#FCD34D" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>3</B></FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">7</FONT></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>role</B></FONT></TD><TD BGCOLOR="#BFDBFE" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#0F172A">left</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FCD34D" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#0F172A">right</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569"> </FONT></TD></TR></TABLE>>];
wrong_note [shape=box style="rounded,filled" fillcolor="#FEE2E2" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" label="Result\\n(7 - 0) * min(1, 3) = 7\\nWidth shrinks, bottleneck stays 1."];
right_move [shape=plain label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8" COLSPAN="10"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>Correct move: discard the short wall</B></FONT></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>index</B></FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">0</FONT></TD><TD BGCOLOR="#BFDBFE" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>1</B></FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">2</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">3</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">4</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">5</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">6</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">7</FONT></TD><TD BGCOLOR="#FCD34D" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>8</B></FONT></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>height</B></FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">1</FONT></TD><TD BGCOLOR="#BFDBFE" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>8</B></FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">6</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">2</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">5</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">4</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">8</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">3</FONT></TD><TD BGCOLOR="#FCD34D" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>7</B></FONT></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>role</B></FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569"> </FONT></TD><TD BGCOLOR="#BFDBFE" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#0F172A">left</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FCD34D" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#0F172A">right</FONT></TD></TR></TABLE>>];
right_note [shape=box style="rounded,filled" fillcolor="#ECFCCB" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" label="Result\\n(8 - 1) * min(8, 7) = 49\\nThis is the global maximum."];
start -> start_note [style=dashed];
start_note -> wrong [label="move taller", color="#DC2626", fontcolor="#DC2626"];
start_note -> right_move [label="move shorter", color="#059669", fontcolor="#059669"];
wrong -> wrong_note [style=dashed color="#DC2626"];
right_move -> right_note [style=dashed color="#059669"];
}
