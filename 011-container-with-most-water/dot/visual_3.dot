digraph G {
graph [rankdir=LR bgcolor="white" margin=0.18 pad=0.2 nodesep=0.45 ranksep=0.5 splines=line]
node [fontname="Helvetica" fontsize=12 color="#94A3B8"]
edge [fontname="Helvetica" fontsize=11 color="#64748B" arrowsize=0.7]
arr [shape=plain label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8" COLSPAN="10"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>Step 1: start with the widest possible pair (0, 8)</B></FONT></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>index</B></FONT></TD><TD BGCOLOR="#BFDBFE" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>0</B></FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">1</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">2</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">3</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">4</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">5</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">6</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">7</FONT></TD><TD BGCOLOR="#FCD34D" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>8</B></FONT></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>height</B></FONT></TD><TD BGCOLOR="#BFDBFE" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>1</B></FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">8</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">6</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">2</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">5</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">4</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">8</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A">3</FONT></TD><TD BGCOLOR="#FCD34D" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>7</B></FONT></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>role</B></FONT></TD><TD BGCOLOR="#BFDBFE" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#0F172A">left / shorter</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">inner</FONT></TD><TD BGCOLOR="#FCD34D" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#0F172A">right / taller</FONT></TD></TR></TABLE>>];
eval [shape=box style="rounded,filled" fillcolor="#F8FAFC" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" label="Evaluate
width = 8
water level = 1
area = 8"];
move [shape=box style="rounded,filled" fillcolor="#DBEAFE" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" label="Decision
height[0] = 1 is the bottleneck.
Move left inward."];
arr -> eval [style=dashed];
eval -> move [label="shorter side decides"];
{ rank=same; arr; eval; move; }
}
