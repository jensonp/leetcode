digraph G {
graph [rankdir=LR bgcolor="white" margin=0.18 pad=0.2 nodesep=0.45 ranksep=0.5 splines=line]
node [fontname="Helvetica" fontsize=12 color="#94A3B8"]
edge [fontname="Helvetica" fontsize=11 color="#64748B" arrowsize=0.7]
small [shape=plain label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8" COLSPAN="3"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>Edge case: with two lines, there is only one possible container</B></FONT></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>index</B></FONT></TD><TD BGCOLOR="#BFDBFE" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>0</B></FONT></TD><TD BGCOLOR="#FCD34D" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>1</B></FONT></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>height</B></FONT></TD><TD BGCOLOR="#BFDBFE" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>1</B></FONT></TD><TD BGCOLOR="#FCD34D" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>1</B></FONT></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="12" COLOR="#0F172A"><B>role</B></FONT></TD><TD BGCOLOR="#BFDBFE" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">left</FONT></TD><TD BGCOLOR="#FCD34D" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT POINT-SIZE="10" COLOR="#475569">right</FONT></TD></TR></TABLE>>];
result [shape=box style="rounded,filled" fillcolor="#ECFCCB" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" label="What happens
Compute area once: (1 - 0) * min(1, 1) = 1
Move one pointer and stop."];
small -> result [style=dashed];
}
