digraph G {
graph [rankdir=TB bgcolor="white" margin=0.18 pad=0.24 nodesep=0.55 ranksep=0.6 labelloc="t" label="212: board DFS only survives along trie prefixes" fontsize=18 fontname="Helvetica-Bold"]
node [fontname="Helvetica" fontsize=12 color="#94A3B8"]
edge [fontname="Helvetica" fontsize=11 color="#64748B" arrowsize=0.7]
board [shape=plain label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" COLSPAN="5" CELLPADDING="10"><B><FONT POINT-SIZE="13">Board path example</FONT></B></TD></TR><TR><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11"> </FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">0</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">1</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">2</FONT></B></TD><TD BGCOLOR="#E2E8F0" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><B><FONT POINT-SIZE="11">3</FONT></B></TD></TR><TR><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">0</FONT></TD><TD BGCOLOR="#FDE68A" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">o</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">a</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">a</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">n</FONT></TD></TR><TR><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">1</FONT></TD><TD BGCOLOR="#FDE68A" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">e</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">t</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">a</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">e</FONT></TD></TR><TR><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">2</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">i</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">h</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">k</FONT></TD><TD BGCOLOR="#FFFFFF" BORDER="1" COLOR="#CBD5E1" CELLPADDING="8"><FONT COLOR="#0F172A" POINT-SIZE="11">r</FONT></TD></TR></TABLE>>];
trie [shape=box style="rounded,filled" fillcolor="#DCFCE7" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Trie path
root -> o -> a -> t
terminal node stores \"oat\"
missing child => prune the DFS branch"];
dedupe [shape=box style="rounded,filled" fillcolor="#FDE68A" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Output once
record the word
clear only the terminal marker
keep deeper shared prefixes intact"];
board -> trie [label="follow matching prefix"];
trie -> dedupe [label="when terminal is reached"];
}
