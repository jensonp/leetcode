j [label="j=-1 (done)", fontcolor=gray];
k [label="k=2", fontcolor=red]; k -> nums1:f2 [color=red];
labelloc="t"; label="Step 4: B[j]=2 >= A[i]=2 — write 2 at k=2, decrement j"; fontsize=14;
}
