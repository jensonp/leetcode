digraph G {
    rankdir=TB;
    node [shape=record, fontname="Helvetica", style=filled, fillcolor=white];
    
    nums1 [label="<f0> 1|<f1> 2|<f2> 3|<f3> 3|<f4> 5|<f5> 6", fillcolor=lightblue];
    nums2 [label="<f0> 2|<f1> 5|<f2> 6", fillcolor=lightyellow];
    
    node [shape=plaintext, fillcolor=none, fontcolor=blue, fontname="Helvetica-Bold"];
    p1 [label="p1=1"]; p1 -> nums1:f1;
p2 [label="p2=0"]; p2 -> nums2:f0;
p [label="p=3"]; p -> nums1:f3 [color=red, fontcolor=red];
    labelloc="t";
    label="Step 3: nums1[p1] (3) > nums2[p2] (2)\nPlace 3 at nums1[p], move p1 and p left";
    fontsize=14;
}
