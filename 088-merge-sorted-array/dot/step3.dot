digraph G {
    rankdir=TB; node [shape=record, fontname="Helvetica", style=filled, fillcolor=white];
    nums1 [label="<f0> 1|<f1> 2|<f2> 3|<f3> 3|<f4> 5|<f5> 6", fillcolor=lightblue];
    nums2 [label="<f0> 2|<f1> 5|<f2> 6", fillcolor=lightyellow];
    node [shape=plaintext, fillcolor=none, fontname="Helvetica-Bold"];
    i [label="i=1", fontcolor=blue]; i -> nums1:f1;
j [label="j=0", fontcolor=darkgreen]; j -> nums2:f0;
k [label="k=3", fontcolor=red]; k -> nums1:f3 [color=red];
labelloc="t"; label="Step 3: A[i]=3 > B[j]=2 — write 3 at k=3, decrement i"; fontsize=14;
}
