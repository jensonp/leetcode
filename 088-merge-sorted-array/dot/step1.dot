digraph G {
    rankdir=TB; node [shape=record, fontname="Helvetica", style=filled, fillcolor=white];
    nums1 [label="<f0> 1|<f1> 2|<f2> 3|<f3> 0|<f4> 0|<f5> 6", fillcolor=lightblue];
    nums2 [label="<f0> 2|<f1> 5|<f2> 6", fillcolor=lightyellow];
    node [shape=plaintext, fillcolor=none, fontname="Helvetica-Bold"];
    i [label="i=2", fontcolor=blue]; i -> nums1:f2;
j [label="j=1", fontcolor=darkgreen]; j -> nums2:f1;
k [label="k=5", fontcolor=red]; k -> nums1:f5 [color=red];
labelloc="t"; label="Step 1: B[j]=6 >= A[i]=3 — write 6 at k=5, decrement j"; fontsize=14;
}
