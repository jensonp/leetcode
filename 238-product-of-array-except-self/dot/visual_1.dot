digraph G {
graph [rankdir=LR bgcolor="white" margin=0.18 pad=0.24 nodesep=0.55 ranksep=0.6 labelloc="t" label="238: Product of Array Except Self: core proof map" fontsize=18 fontname="Helvetica-Bold"]
node [fontname="Helvetica" fontsize=12 color="#94A3B8"]
edge [fontname="Helvetica" fontsize=11 color="#64748B" arrowsize=0.7]
top [shape=plaintext fontname="Helvetica-Bold" fontsize=15 label="238: Product of Array Except Self"];
state [shape=box style="rounded,filled" fillcolor="#DBEAFE" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="State Model
For each index `i`, define: -
`prefix[i]` = product of
`nums[0..i-1]`, - `suffix[i]`
= product of `nums[i+1..n-1]`."];
claim [shape=box style="rounded,filled" fillcolor="#DCFCE7" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Prefix-Suffix Lemma
The factors contributing to
`ans[i]` split into the
product strictly left of `i`
and the product strictly right
..."];
action [shape=box style="rounded,filled" fillcolor="#FDE68A" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Algorithm Consequence
Store prefix products directly
in `ans`, then multiply by a
running suffix product."];
proof [shape=box style="rounded,filled" fillcolor="#FCE7F3" color="#94A3B8" penwidth=1.2 margin="0.18,0.12" fontname="Helvetica" fontsize=12 label="Why It Works
After the first pass, `ans[i]`
equals the product of all
entries strictly left of `i`."];
top -> state [style=invis];
state -> claim [label="sets up"];
claim -> action [label="justifies"];
action -> proof [label="preserves"];
{ rank=same; state; claim; action; proof }
}
